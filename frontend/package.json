{
  "name": "recipe-companion-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:runtime\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:runtime": "tsx server/runtime.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.35",
    "@copilotkit/react-core": "^1.57.1",
    "@copilotkit/react-ui": "^1.57.1",
    "@copilotkit/runtime": "^1.57.1",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.4",
    "vite": "^6.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.8.0"
  }
}
